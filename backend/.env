DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=hr_agent_user
DATABASE_PASSWORD=hr_agent_password
DATABASE_NAME=hr_agent
# 远程服务配置
HR_SERVICE_HOST=121.43.198.13 # 远程服务主机地址
HR_SERVICE_PORT=8000 # 远程服务端口
HR_SERVICE_APIKEY=ca64bab853bb45cb94c005c299af30d3
# CORS 设置
BACKEND_CORS_ORIGINS=
["http://localhost:3000","http://localhost:8080","http://localhost:5173"]
# LLM 设置
LLM_API_KEY==sk-ws-H.RXDEIYD.jlXg.MEUCIQCb3rOMxV_KlSYfkIwfu5l0txjOGTQQgD-fscP-2l16BgIgCc1dp-rKAU9bZIggF2-xLEHER74wbw7N6zh-CSEjQeM
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen3.7-max
# Qwen 重排序设置
QWEN_API_KEY=sk-ws-H.RXDEIYD.jlXg.MEUCIQCb3rOMxV_KlSYfkIwfu5l0txjOGTQQgD-fscP-2l16BgIgCc1dp-rKAU9bZIggF2-xLEHER74wbw7N6zh-CSEjQeM
QWEN_MODEL=gte-rerank-v2
# 嵌⼊设置
EMBEDDING_API_KEY==sk-ws-H.RXDEIYD.jlXg.MEUCIQCb3rOMxV_KlSYfkIwfu5l0txjOGTQQgD-fscP-2l16BgIgCc1dp-rKAU9bZIggF2-xLEHER74wbw7N6zh-CSEjQeM
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL=text-embedding-v1
# 查询改写设置
KB_QUERY_ENHANCE_ENABLED=true # 启⽤查询改写功能
KB_QUERY_EXPANSION_MAX_TERMS=6 # 查询扩展最⼤术语数量
# 向量数据库（pgvector）
VECTOR_DIMENSION=1536
# ⽂件上传设置
MAX_FILE_SIZE=10485760 # 10MB（字节）
ALLOWED_FILE_TYPES=["pdf","docx","txt","md"]

UPLOAD_DIR=uploads
# ⽇志配置
LOG_LEVEL=INFO
# 远程服务请求/响应⽇志配置
REMOTE_SERVICE_LOG_ENABLED=false # 是否输出远程服务请求/响应详情
# 上下⽂配置
CONTEXT_LIMIT=5
# Dify ⼯作流配置
# DIFY_BASE_URL=http://nginx.docker.orb.local/v1
DIFY_BASE_URL=http://localhost/v1
DIFY_API_KEY=app-HRXhvHcnpCbEYFYzyvbTduqe
DIFY_USER_ID=hr-agent-user
# 重排序设置
RERANK_ENABLED=true
RERANK_TOP_K=10
RERANK_FINAL_K=10
# RAG 分数组合权重设置
RAG_CONTENT_WEIGHT=0.7 # 向量相似度权重
RAG_TEXT_WEIGHT=0.3 # ⽂本匹配权重